+        wait(0);
+    }
+    else {
+        // child
+        close(p2c[1]);
+        close(c2p[0]);
+        read(p2c[0], buffer, 1);
+        printf("%d: received ping\n", getpid());
+        write(c2p[1], "x", 1);
+        close(p2c[0]);
+        close(c2p[1]);
